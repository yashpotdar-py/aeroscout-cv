# ─── AeroScout-CV — Root Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Backend ────────────────────────────────────────────────────────────────────
# Path to the flood segmentation model weights (flood_unet.pth)
# If not set, inference will be skipped gracefully (demo mode still works).
MODEL_PATH=models/flood_unet.pth

# MAVLink connection string for the Pixhawk flight controller
# UDP from Mission Planner:   udpin:0.0.0.0:14550
# Direct serial (Windows):    COM3
# Direct serial (Linux):      /dev/ttyUSB0
MAVLINK_CONNECTION=udpin:0.0.0.0:14550

# Log level for uvicorn/FastAPI
LOG_LEVEL=info

# ── Frontend ───────────────────────────────────────────────────────────────────
# WebSocket URL for the backend (used by Docker Compose or remote deploy)
VITE_BACKEND_WS_URL=ws://localhost:8000/ws

# HTTP URL for REST endpoints
VITE_BACKEND_HTTP_URL=http://localhost:8000
