# ─── AeroScout Backend — Environment Variables ─────────────────────────────────
# Copy to .env and fill in your values. Never commit .env.

# Path to the flood segmentation model weights (flood_unet.pth)
# Inference is skipped gracefully if this file does not exist.
MODEL_PATH=models/flood_unet.pth

# MAVLink connection string for the Pixhawk / ArduPilot flight controller
# UDP from Mission Planner:   udpin:0.0.0.0:14550
# Direct serial (Windows):    COM3
# Direct serial (Linux):      /dev/ttyUSB0
MAVLINK_CONNECTION=udpin:0.0.0.0:14550

# Uvicorn log level: debug | info | warning | error | critical
LOG_LEVEL=info
